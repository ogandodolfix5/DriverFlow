<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@ViewData["Title"] - DriverFlow</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <style>
    :root {
        --primary: #0d6efd;
    }

    body {
        background-color: #f8f9fa;
    }

    .card {
        border-radius: 12px;
        box-shadow: 0 6px 16px rgba(0,0,0,0.1);
    }

    /* ← Aquí usa doble arroba */
    @@media (max-width: 576px) {
        .card-body {
            padding: 1rem;
        }

        .btn {
            width: 100%;
            padding: 0.8rem;
            margin-bottom: 10px;
        }

        h1, h2, h3 {
            font-size: 1.4rem;
        }
    }
</style>
 
</head>

<body>
    <!-- Navbar -->
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
           <a class="navbar-brand d-flex align-items-center fw-bold" href="/">
    <img src="~/images/logo.png" alt="DriverCash" style="height: 45px; margin-right: 10px;" />
    DriverFlow
</a>

            <!-- Resto del navbar... -->
        </div>


        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- Menú completo solo para usuarios logueados -->
            <span class="navbar-text text-light me-auto">
                👋 Hola, <strong>@User.Identity.Name</strong>
            </span>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Reports/Index">Reportes</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Profile">Mi Perfil</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/About">¿Cómo funciona?</a></li>
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-area="Identity" asp-page="/Account/Logout">Cerrar Sesión</a>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <!-- Solo opciones de login cuando no está logueado -->
            <div class="ms-auto">
                <a class="btn btn-outline-light me-2" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
                <a class="btn btn-light" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
            </div>
        }
    </div>
</nav>

<!-- Contenido principal -->
<div class="container mt-4">
    @RenderBody()
</div>

<footer class="bg-dark text-light text-center py-4 mt-5">
    © 2026 - DriverFlow - Drivers
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>

</html>