@model MoneyTracker.Models.Goal

<div class="modal fade" id="setGoalModal" tabindex="-1" aria-labelledby="goalModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg">
            
            <!-- FORMULARIO QUE ENVUELVE TODO -->
            <form asp-action="SetGoal" asp-controller="Goals" method="post">
                @Html.AntiForgeryToken()

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="goalModalLabel">
                        <i class="bi bi-trophy-fill"></i> Configurar Meta Mensual
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="form-label fw-bold">Monto de la Meta (RD$)</label>
                        <input asp-for="MontoMeta" type="number" step="0.01" class="form-control form-control-lg" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Inicio</label>
                            <input asp-for="FechaInicio" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Fin</label>
                            <input asp-for="FechaFin" type="date" class="form-control" required />
                        </div>
                    </div>

                    <div class="form-check mt-3">
                        <input asp-for="Activa" type="checkbox" class="form-check-input" checked />
                        <label class="form-check-label fw-bold">Mantener esta meta activa</label>
                    </div>
                </div>

                <!-- Botón DENTRO del formulario -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Guardar Meta
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>