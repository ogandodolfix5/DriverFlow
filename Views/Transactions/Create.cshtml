@model MoneyTracker.Models.Transaction

<div class="modal fade" id="addTransactionModal" tabindex="-1" aria-labelledby="transactionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="transactionModalLabel">
                    <i class="bi bi-plus-circle"></i> Agregar Ingreso / Gasto
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body">
                <form id="transactionForm" asp-action="Create" asp-controller="Transactions" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Fecha</label>
                            <input asp-for="Fecha" type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Aplicación</label>
                            <select asp-for="Aplicacion" class="form-select" required>
                                <option value="">Seleccione...</option>
                                <option value="Uber">Uber</option>
                                <option value="InDrive">InDrive</option>
                                <option value="DiDi">DiDi</option>
                                <option value="Cabify">Cabify</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tanda Horaria</label>
                            <select asp-for="TandaHoraria" class="form-select">
                                <option value="">Seleccione tanda...</option>
                                <option value="Mañana">🌅 Mañana</option>
                                <option value="Tarde">☀️ Tarde</option>
                                <option value="Noche">🌙 Noche</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Monto Bruto (RD$)</label>
                            <input asp-for="MontoBruto" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>

                    <h6 class="mt-3 mb-3 text-danger"><i class="bi bi-cash-stack"></i> Gastos</h6>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Gasolina</label>
                            <input asp-for="Gasolina" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Mantenimiento</label>
                            <input asp-for="Mantenimiento" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Comida</label>
                            <input asp-for="Comida" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Otros</label>
                            <input asp-for="OtrosGastos" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tips (RD$)</label>
                            <input asp-for="Tips" type="number" step="0.01" value="0" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Notas / Incidencias</label>
                        <textarea asp-for="Notas" class="form-control" rows="3" placeholder="Cliente canceló, mucho tráfico, etc."></textarea>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" form="transactionForm" class="btn btn-success">
                    <i class="bi bi-save"></i> Guardar Transacción
                </button>
            </div>
        </div>
    </div>
</div>