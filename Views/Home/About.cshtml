@model dynamic 

@{
    ViewData["Title"] = "¿Cómo funciona? - DriverFlow";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">¿Cómo funciona DriverFlow?</h1>
        <p class="lead text-muted">Tu asistente inteligente para maximizar ganancias como driver</p>
    </div>

    <!-- Pasos principales -->
    <div class="row g-5">
        
        <!-- Paso 1 -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        📱
                    </div>
                    <h4 class="fw-bold">1. Registra tus viajes rápido</h4>
                    <p class="text-muted">
                        Ingresa en segundos: Monto Bruto, Gastos, Tips, Aplicación (Uber, InDrive, etc.) 
                        y la tanda horaria.
                    </p>
                </div>
            </div>
        </div>

        <!-- Paso 2 -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        📊
                    </div>
                    <h4 class="fw-bold">2. Cálculos automáticos</h4>
                    <p class="text-muted">
                        DriverFlow calcula automáticamente tu <strong>Neto real</strong>, 
                        total de gastos y genera reportes por aplicación y por tanda horaria.
                    </p>
                </div>
            </div>
        </div>

        <!-- Paso 3 -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-warning text-dark rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        🎯
                    </div>
                    <h4 class="fw-bold">3. Controla tus metas</h4>
                    <p class="text-muted">
                        Define una meta mensual y sigue tu progreso en tiempo real con mensajes motivadores.
                    </p>
                </div>
            </div>
        </div>

        <!-- Paso 4 -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-info text-white rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        📧
                    </div>
                    <h4 class="fw-bold">4. Reportes inteligentes</h4>
                    <p class="text-muted">
                        Filtra por fechas y envía reportes detallados a tu correo con un solo clic.
                    </p>
                </div>
            </div>
        </div>

        <!-- Paso 5 -->
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 border-0 shadow">
                <div class="card-body text-center p-4">
                    <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" 
                         style="width: 80px; height: 80px; font-size: 2rem;">
                        🛡️
                    </div>
                    <h4 class="fw-bold">5. Datos seguros</h4>
                    <p class="text-muted">
                        Tu información está protegida. Solo tú puedes ver tus reportes y transacciones.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Beneficios finales -->
    <div class="card shadow mt-5 bg-light">
        <div class="card-body p-5 text-center">
            <h3 class="mb-4">🚀 ¿Por qué miles de drivers usan DriverFlow?</h3>
            <div class="row text-start g-4">
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-3">✅ Control total de tus ganancias reales</li>
                        <li class="mb-3">✅ Saber qué aplicación te conviene más</li>
                        <li class="mb-3">✅ Identificar las mejores tandas horarias</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-3">✅ Nunca más perder dinero por gastos ocultos</li>
                        <li class="mb-3">✅ Metas claras y motivación diaria</li>
                        <li class="mb-3">✅ Reportes profesionales por correo</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Puedes agregar animaciones o Chart.js aquí si quieres -->
}